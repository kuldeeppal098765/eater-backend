# Copy to .env and fill in. Never commit .env.

# Required for admin + partner API sessions (JWT). Use a long random string in production.
JWT_SECRET=
# Optional token lifetime (default 7d). Examples: 8h, 7d, 30d
# JWT_EXPIRES_IN=7d

# Required for Partner → Menu Studio → "Digitize Menu with AI" (Gemini)
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: preferred model(s), comma-separated. If unset, server calls Google ListModels and picks a working Flash model.
# GEMINI_MODEL=gemini-2.0-flash

PORT=5000

# Admin panel OTP login — last 10 digits (comma-separated for multiple)
# ADMIN_PHONE=8299393771
# ADMIN_ALLOWED_PHONES=8299393771,9999999999

# --- Twilio WhatsApp OTP (optional; if unset, OTP is only printed in server logs) ---
# https://console.twilio.com — Account SID & Auth Token
# WhatsApp sender: Sandbox uses whatsapp:+14155238886 until you go live with your own number.
# Content SID: approved WhatsApp template in Twilio (Content Editor) with at least one variable for the OTP.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
# Which template placeholder gets the 4-digit OTP (usually "1" for {{1}})
# TWILIO_WHATSAPP_OTP_VAR=1
# Extra template variables as JSON, e.g. {"2":"Fresto"}
# TWILIO_WHATSAPP_EXTRA_VARS_JSON=
# Default country for whatsapp:+<cc><10-digit>
# TWILIO_PHONE_COUNTRY_PREFIX=91

# Digit count for USER/PARTNER/RIDER login OTP (match WhatsApp template + frontend VITE_OTP_LENGTH)
# OTP_CODE_LENGTH=6

# --- Paytm (optional — online payments) ---
# Sandbox dashboard: https://dashboard.paytm.com/next/sandbox
# PAYTM_ENV=sandbox
# PAYTM_ENV=production
# PAYTM_MID=
# PAYTM_MERCHANT_KEY=
# PAYTM_WEBSITE=WEBSTAGING
# PAYTM_INDUSTRY_TYPE=Retail
# PAYTM_CHANNEL_ID=WEB
# WAP is for native apps only; website checkout should use WEB.
# Each Paytm payment attempt uses a fresh merchant order id (uuid+timestamp) so "Pay again" works.
# Full URL Paytm should call after payment (must be reachable from the internet for real tests; use ngrok locally)
# PAYTM_CALLBACK_URL=https://your-domain.com/api/payment/paytm-callback
# Or set a public API base and the server will append /api/payment/paytm-callback
# APP_PUBLIC_URL=https://your-domain.com

# --- VYAHARAM admin Telegram alerts (live support) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Optional: Socket.IO CORS (comma-separated origins). Default: allow all.
# SOCKET_CORS_ORIGIN=http://localhost:5173
